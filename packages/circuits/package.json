{
  "description": "Circomkit examples",
  "type": "module",
  "scripts": {
    "start": "pnpm ./src/index.ts",
    "test": "mocha --node-option=import=tsx --timeout 300000 'tests/**/*.test.ts'",
    "compile": "run-s compile:*",
    "info": "run-s info:*",
    "circomspect": "run-s circomspect:*",
    "compile:aggregator": "pnpm circomkit compile aggregator",
    "info:aggregator": "pnpm circomkit info aggregator",
    "circomspect:aggregator": "circomspect aggregator",
    "prove:aggregator": "pnpm circomkit prove aggregator",
    "verify:aggregator": "pnpm circomkit verify aggregator"
  },
  "dependencies": {
    "@zkpassport/poseidon2": "^0.6.2",
    "circomkit": "^0.0.22",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "viem": "^2.53.1"
  },
  "devDependencies": {
    "@types/circomlibjs": "^0.1.6",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.3.0",
    "@zk-kit/lean-imt": "^2.2.4",
    "mocha": "^10.2.0",
    "poseidon-lite": "^0.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.1.3"
  }
}